{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ToeBox Documentation",
  "colors": {
    "primary": "#303030",
    "light": "#4A4A4A",
    "dark": "#1A1A1A"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Agents",
            "pages": ["guides/creating-agents", "guides/agent-tools", "guides/mcp-connections"]
          },
          {
            "group": "Chatbot Widget",
            "pages": ["guides/chatbot-setup", "guides/chatbot-customization", "guides/embed-widget"]
          },
          {
            "group": "Analytics",
            "pages": ["guides/dashboards", "guides/ai-assistant", "guides/data-sources"]
          },
          {
            "group": "Integrations",
            "pages": ["guides/shopify-connections", "guides/data-warehouses", "guides/byok"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Overview",
            "pages": ["api-reference/introduction", "api-reference/authentication"]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/chat",
              "api-reference/endpoint/agents",
              "api-reference/endpoint/widget-config"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App Store",
          "href": "https://apps.shopify.com",
          "icon": "shop"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@toebox.ai",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@toebox.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://apps.shopify.com"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/sashimiboi"
    }
  }
}
